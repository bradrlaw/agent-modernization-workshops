{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.5",
  "body": [
    {
      "type": "Container",
      "style": "emphasis",
      "items": [
        {
          "type": "TextBlock",
          "text": "📊 Current Loan Rates",
          "weight": "Bolder",
          "size": "Medium"
        },
        {
          "type": "TextBlock",
          "text": "As of ${lastUpdated}",
          "spacing": "None",
          "isSubtle": true,
          "size": "Small"
        }
      ]
    },
    {
      "type": "Container",
      "$data": "${rates}",
      "separator": true,
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "${productType}",
                  "weight": "Bolder",
                  "size": "Small"
                },
                {
                  "type": "TextBlock",
                  "text": "${term}",
                  "size": "Small",
                  "isSubtle": true,
                  "spacing": "None"
                }
              ]
            },
            {
              "type": "Column",
              "width": "auto",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "${minRate}% – ${maxRate}%",
                  "weight": "Bolder",
                  "size": "Small",
                  "horizontalAlignment": "Right"
                }
              ],
              "verticalContentAlignment": "Center"
            }
          ]
        }
      ]
    },
    {
      "type": "TextBlock",
      "text": "${disclaimer}",
      "wrap": true,
      "size": "Small",
      "isSubtle": true
    }
  ]
}
