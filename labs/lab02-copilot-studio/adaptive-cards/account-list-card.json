{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.5",
  "body": [
    {
      "type": "Container",
      "style": "emphasis",
      "items": [
        {
          "type": "TextBlock",
          "text": "🏦 Your Accounts",
          "weight": "Bolder",
          "size": "Medium"
        },
        {
          "type": "TextBlock",
          "text": "Welcome, ${customerName}",
          "spacing": "None",
          "isSubtle": true
        }
      ]
    },
    {
      "type": "Container",
      "$data": "${accounts}",
      "separator": true,
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "${nickname}",
                  "weight": "Bolder",
                  "size": "Small"
                },
                {
                  "type": "TextBlock",
                  "text": "${type} ••••${last4}",
                  "size": "Small",
                  "isSubtle": true,
                  "spacing": "None"
                }
              ]
            },
            {
              "type": "Column",
              "width": "auto",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "$${currentBalance}",
                  "weight": "Bolder",
                  "horizontalAlignment": "Right",
                  "size": "Small"
                },
                {
                  "type": "TextBlock",
                  "text": "${status}",
                  "size": "Small",
                  "isSubtle": true,
                  "horizontalAlignment": "Right",
                  "spacing": "None"
                }
              ],
              "verticalContentAlignment": "Center"
            }
          ]
        }
      ]
    },
    {
      "type": "Container",
      "style": "emphasis",
      "items": [
        {
          "type": "TextBlock",
          "text": "Total Balance: $${totalBalance}",
          "weight": "Bolder",
          "horizontalAlignment": "Right"
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Action.Submit",
      "title": "View Balance Details",
      "data": {
        "action": "viewBalance"
      }
    },
    {
      "type": "Action.Submit",
      "title": "Recent Transactions",
      "data": {
        "action": "viewTransactions"
      }
    }
  ]
}
