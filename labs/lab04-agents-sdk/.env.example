# Microsoft 365 Agents SDK / Azure Bot auth
# In ASP.NET Core, "__" (double underscore) maps to nested appsettings.json keys, so
# these override Agents:Connections:BotServiceConnection:Settings without editing the file.
Agents__Connections__BotServiceConnection__Settings__ClientId=<entra-app-client-id>
Agents__Connections__BotServiceConnection__Settings__ClientSecret=<entra-app-client-secret>
Agents__Connections__BotServiceConnection__Settings__TenantId=<entra-tenant-id>

# Hosting (local dev binds to 3978 via Properties/launchSettings.json)
ASPNETCORE_URLS=http://localhost:3978

# Optional stretch goal - Azure AI Foundry (maps to the AzureAI section of appsettings.json)
AzureAI__ProjectEndpoint=https://<your-project>.services.ai.azure.com/api/projects/<your-project-id>
AzureAI__ModelDeployment=<your-model-deployment-name>
